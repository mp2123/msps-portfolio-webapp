// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  scores    Score[]
  createdAt DateTime @default(now())
}

model Question {
  id          Int      @id @default(autoincrement())
  text        String
  options     String[] // Array of strings for the multiple choice options
  answer      String   // The correct option text
  explanation String?
  category    String?
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: id)
  total     Int
  correct   Int
  timestamp DateTime @default(now())
}

model PortfolioEvent {
  id        String   @id @default(cuid())
  eventType String
  label     String?
  href      String?
  section   String?
  sessionId String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([sessionId, createdAt])
}

model AssistantCacheEntry {
  id                 String   @id @default(cuid())
  cacheKey           String   @unique
  strategy           String
  intent             String?
  normalizedQuestion String?
  responseText       String
  provider           String
  modelId            String
  contentVersion     String
  hitCount           Int      @default(0)
  createdAt          DateTime @default(now())
  expiresAt          DateTime
  lastHitAt          DateTime @default(now())

  @@index([expiresAt])
  @@index([intent, expiresAt])
  @@index([createdAt])
}

model InvisibleInkMessage {
  id                 String   @id @default(cuid())
  sessionId          String
  visitorHash        String?
  alias              String?
  message            String
  createdFromCity    String?
  createdFromRegion  String?
  createdFromCountry String?
  createdAt          DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId, createdAt])
  @@index([visitorHash, createdAt])
}
